# Google OAuth2
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Add these redirect URIs to your OAuth client:
#   http://localhost:5173/auth/google/callback   (dev — goes through Vite proxy)
#   https://your-domain.com/auth/google/callback (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Dev: use the Vite port (5173) so the browser cookie is set on the same origin as the frontend.
# Prod: use your real domain (no port — Railway/SSL terminates externally).
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google/callback

# Session — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars

# Server
PORT=3001
HOST=0.0.0.0

# Frontend URL — where to redirect after login
# Dev: Vite dev server
# Prod: your public domain
FRONTEND_URL=http://localhost:5173

# Database (Prisma)
# SQLite (dev / single-server prod):
DATABASE_URL="file:../data/app.db"
# PostgreSQL (prod):
# DATABASE_URL="postgresql://user:password@host:5432/transcriber?schema=public"
# Also change prisma/schema.prisma: provider = "postgresql"
